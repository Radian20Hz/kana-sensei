# ══════════════════════════════════════════════
#  KanaSensei — .gitignore
# ══════════════════════════════════════════════

# ─── Firebase credentials & config ────────────
.env
.env.*
.firebaserc
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
ui-debug.log
public/js/config.js
public/js/config.local.js

# ─── Firebase Hosting / Emulator ──────────────
.firebase/
firestore.rules
firestore.indexes.json
database.rules.json

# ─── Node / npm (if you ever add tooling) ─────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ─── OS junk ──────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini

# ─── Editor folders ───────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ─── Build artifacts (future-proofing) ────────
dist/
build/
.cache/